# ===== MCPHubs Configuration =====
# Copy this file to .env and fill in your values.

# --- PostgreSQL ---
MCPHUBS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcphubs

# --- Security ---
# JWT secret (CHANGE THIS in production!)
MCPHUBS_JWT_SECRET=change-me-to-a-random-string

# --- Admin ---
MCPHUBS_ADMIN_USERNAME=admin
MCPHUBS_ADMIN_PASSWORD=admin123
